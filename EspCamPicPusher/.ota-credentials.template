# OTA Server Credentials
# Copy this file to .ota-credentials and fill in your values
# The .ota-credentials file is gitignored for security

# OTA server base URL (without trailing slash)
OTA_SERVER_URL=https://your-server.com

# HTTP Basic Auth credentials for OTA upload endpoint
OTA_USERNAME=admin
OTA_PASSWORD=your_password_here

# Optional: Firmware description
OTA_DESCRIPTION="Automated build"
