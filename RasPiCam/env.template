# Environment configuration for capture-upload-image.sh
# Copy this file to 'env' and customize the values for your installation
# Usage: source env && ./capture-upload-image.sh

# Camera device identifier (used as X-Device-ID header)
# This name will appear in the web interface
CAM_NAME="CoolCam"

# Authentication token for upload API
# Must match one of the tokens in WebCamPics/config/config.json
CAM_AUTH_TOKEN="your-secret-token-here"

# Upload endpoint URL
# Point this to your WebCamPics installation
CAM_POSTHANDLER="https://yourdomain.com/cams/upload.php"
